<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pink_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end">

            <Button
                android:id="@+id/btnBackCheckout"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_back_cart_round"
                android:backgroundTint="@null"
                android:text="← Quay lại"
                android:textAllCaps="false"
                android:textColor="@color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_form_rounded"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtCheckoutProduct"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tên sản phẩm"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtCheckoutOption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Thông tin món"
                android:textColor="#666666"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtDiscountInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Chưa áp dụng mã giảm giá"
                android:textColor="#777777"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtCheckoutTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Tổng tiền: 0đ"
                android:textColor="@color/pink_main"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <EditText
            android:id="@+id/edtReceiverName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="Tên người nhận"
            android:padding="12dp" />

        <EditText
            android:id="@+id/edtReceiverPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="Số điện thoại"
            android:inputType="phone"
            android:padding="12dp" />

        <EditText
            android:id="@+id/edtReceiverAddress"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_rounded"
            android:gravity="top|start"
            android:hint="Địa chỉ giao hàng"
            android:padding="12dp" />

        <CheckBox
            android:id="@+id/chkSaveDefaultAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Lưu làm địa chỉ mặc định" />

        <EditText
            android:id="@+id/edtOrderNote"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_rounded"
            android:gravity="top|start"
            android:hint="Ghi chú cho đơn hàng"
            android:padding="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/edtCouponCode"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_rounded"
                android:hint="Mã giảm giá"
                android:padding="12dp" />

            <Button
                android:id="@+id/btnApplyCoupon"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_form_rounded"
                android:backgroundTint="@null"
                android:text="Áp dụng"
                android:textAllCaps="false"
                android:textColor="@color/pink_dark" />
        </LinearLayout>
        <TextView
            android:id="@+id/txtVoucherHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Mã áp dụng: GIAM10 (10%), GIAM20K (20.000đ), FREESHIP (15.000đ)"
            android:textColor="#777777"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Phương thức thanh toán"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgPaymentMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp">

            <RadioButton
                android:id="@+id/rbCash"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Tiền mặt" />

            <RadioButton
                android:id="@+id/rbBanking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chuyển khoản" />

            <RadioButton
                android:id="@+id/rbMomo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ví MoMo" />
        </RadioGroup>

        <Button
            android:id="@+id/btnConfirmOrder"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_pink"
            android:backgroundTint="@null"
            android:text="Xác nhận đặt hàng"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />
    </LinearLayout>
</ScrollView>
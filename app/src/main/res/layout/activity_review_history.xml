<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pink_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <Button
        android:id="@+id/btnBackReviewHistory"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="end"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_back_cart_round"
        android:backgroundTint="@null"
        android:text="← Quay lại"
        android:textAllCaps="false"
        android:textColor="@color/white" />
    <TextView
        android:id="@+id/txtReviewHistoryTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Lịch sử đánh giá của bạn"
        android:textColor="@color/pink_dark"
        android:textSize="20sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvReviewHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1" />
</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pink_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/btnBackStoreInfo"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_back_cart_round"
            android:backgroundTint="@null"
            android:text="← Quay lại"
            android:textAllCaps="false"
            android:textColor="@color/pink_dark" />

        <EditText
            android:id="@+id/edtShopName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Tên cửa hàng"
            android:background="@drawable/bg_input_rounded"
            android:padding="12dp" />

        <EditText
            android:id="@+id/edtPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Số điện thoại"
            android:background="@drawable/bg_input_rounded"
            android:padding="12dp" />

        <EditText
            android:id="@+id/edtEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Email"
            android:background="@drawable/bg_input_rounded"
            android:padding="12dp" />

        <EditText
            android:id="@+id/edtAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Địa chỉ"
            android:background="@drawable/bg_input_rounded"
            android:padding="12dp" />

        <Button
            android:id="@+id/btnSaveStoreInfo"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_button_pink"
            android:backgroundTint="@null"
            android:text="Lưu thông tin"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />
    </LinearLayout>
</ScrollView>
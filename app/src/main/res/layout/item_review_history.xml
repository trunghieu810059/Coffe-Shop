<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_form_rounded"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/txtReviewStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trạng thái: Đang hiển thị"
        android:textColor="@color/pink_dark"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtReviewTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="21/04/2026 20:00"
        android:textColor="#777777"
        android:textSize="12sp" />

    <RatingBar
        android:id="@+id/ratingBarReviewHistory"
        style="?android:attr/ratingBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:isIndicator="true"
        android:numStars="5"
        android:stepSize="0.5"
        android:progressTint="#FFC107"
        android:secondaryProgressTint="#FFE082"
        android:progressBackgroundTint="#E0E0E0" />

    <TextView
        android:id="@+id/txtReviewComment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Nội dung đánh giá"
        android:textColor="@android:color/black"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/txtAdminReply"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Phản hồi từ quán"
        android:textColor="@color/pink_dark"
        android:textStyle="bold" />
</LinearLayout>